{
  "name": "host-git-cred-proxy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Bun-first host service and UI workspace for host-git-cred-proxy.",
  "scripts": {
    "check": "bun run check:types && bun run check:shell",
    "check:types": "tsc --project tsconfig.host.json --noEmit && tsc --project host/ui/tsconfig.json --noEmit",
    "check:shell": "bash -n host/start.sh host/stop.sh host/status.sh container/configure-git.sh container/git-credential-hostproxy container/install.sh",
    "test": "bun test tests/host tests/container",
    "test:ui": "vitest run --config host/ui/vite.config.ts --passWithNoTests",
    "test:e2e": "bunx playwright test",
    "build:host": "bun build host/src/index.ts --target=bun --outdir=dist/host",
    "build:ui": "vite build --config host/ui/vite.config.ts",
    "build": "bun run build:host && bun run build:ui",
    "package:release": "bun run scripts/package-release.ts",
    "smoke:tarball": "bun test tests/release/tarball-smoke.test.ts",
    "smoke:brew": "bun run scripts/generate-formula.ts && bun test tests/release/smoke-brew.test.ts",
    "smoke:network-contract": "bash ./scripts/smoke-network-contract.sh",
    "smoke:container-install": "bun test tests/container/install-smoke.test.ts"
  },
  "dependencies": {
    "@elysiajs/static": "^1.3.0",
    "elysia": "^1.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/bun": "latest",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react": "^4.4.1",
    "jsdom": "28.1.0",
    "typescript": "^5.7.3",
    "vite": "^5.4.14",
    "vitest": "^3.0.7"
  },
  "engines": {
    "bun": ">=1.3.10"
  }
}
